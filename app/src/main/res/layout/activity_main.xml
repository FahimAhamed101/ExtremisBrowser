<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/chrome_page_bg">

    <LinearLayout
        android:id="@+id/browserContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/topControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="8dp">

            <ImageButton
                android:id="@+id/homeButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/open"
                android:padding="8dp"
                android:src="@drawable/ic_home_24" />

            <LinearLayout
                android:id="@+id/compactUrlBar"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="8dp"
                android:layout_weight="1"
                android:background="@drawable/chrome_search_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="4dp">

                <EditText
                    android:id="@+id/urlInput"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/search_or_type_url"
                    android:imeOptions="actionGo"
                    android:inputType="textUri"
                    android:maxLines="1"
                    android:padding="0dp"
                    android:singleLine="true"
                    android:textColor="@color/chrome_text"
                    android:textColorHint="@color/chrome_muted"
                    android:textSize="16sp" />

                <ImageButton
                    android:id="@+id/reloadButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/refresh"
                    android:padding="8dp"
                    android:src="@drawable/ic_reload_24" />
            </LinearLayout>

            <Space
                android:id="@+id/homeTopSpacer"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/profileButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/settings"
                android:padding="8dp"
                android:src="@drawable/ic_account_24" />

            <TextView
                android:id="@+id/tabCountButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:textColor="@color/chrome_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/menuButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/menu"
                android:padding="8dp"
                android:src="@drawable/ic_more_vert_24" />
        </LinearLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:indicatorColor="@color/chrome_blue"
            app:trackColor="@color/chrome_search_bg" />

        <FrameLayout
            android:id="@+id/contentFrame"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/swipeRefresh"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <WebView
                    android:id="@+id/webView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

            <ScrollView
                android:id="@+id/homeScroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:id="@+id/homeContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="14dp"
                    android:paddingTop="18dp"
                    android:paddingBottom="28dp">

                    <TextView
                        android:id="@+id/googleLogo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="8dp"
                        android:text="@string/app_name"
                        android:textColor="@color/extremis_blue"
                        android:textSize="36sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/incognitoLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="8dp"
                        android:text="@string/incognito_home"
                        android:textColor="@color/chrome_muted"
                        android:textSize="16sp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/homeSearchBar"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/chrome_search_bg"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="22dp"
                        android:paddingEnd="8dp">

                        <EditText
                            android:id="@+id/homeSearchInput"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:hint="@string/search_or_type_url"
                            android:imeOptions="actionGo"
                            android:inputType="textUri"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:textColor="@color/chrome_text"
                            android:textColorHint="@color/chrome_text"
                            android:textSize="16sp" />

                        <ImageButton
                            android:id="@+id/voiceButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/search_or_type_url"
                            android:padding="8dp"
                            android:src="@drawable/ic_mic_24" />

                        <ImageButton
                            android:id="@+id/lensButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/search_or_type_url"
                            android:padding="8dp"
                            android:src="@drawable/ic_camera_24" />
                    </LinearLayout>

                    <HorizontalScrollView
                        android:id="@+id/quickLinksScroller"
                        android:layout_width="match_parent"
                        android:layout_height="110dp"
                        android:layout_marginTop="22dp"
                        android:background="@drawable/chrome_card_bg"
                        android:clipToPadding="false"
                        android:fillViewport="false"
                        android:overScrollMode="never"
                        android:paddingHorizontal="14dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/quickLinksContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>

                    <LinearLayout
                        android:id="@+id/continueCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/chrome_card_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/continue_with_this_tab"
                                android:textColor="@color/chrome_text"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/seeMoreButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/see_more"
                                android:textColor="@color/chrome_blue"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="96dp"
                                android:layout_height="96dp"
                                android:background="@drawable/continue_thumb_bg"
                                android:gravity="center"
                                android:padding="8dp"
                                android:text="Resume\nyour last\npage"
                                android:textColor="@color/extremis_blue"
                                android:textSize="11sp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Continue browsing from your recent session"
                                    android:textColor="@color/chrome_text"
                                    android:textSize="17sp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="26dp"
                                    android:text="@string/app_name"
                                    android:textColor="@color/chrome_muted"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/nativeAdContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/discoverCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/chrome_card_bg"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/discover"
                                android:textColor="@color/chrome_text"
                                android:textSize="14sp" />

                            <ImageButton
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:padding="8dp"
                                android:src="@drawable/ic_more_vert_24" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/discoverPrimary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Keep your browsing private with tabs, downloads, and saved pages"
                                    android:textColor="@color/chrome_text"
                                    android:textSize="18sp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="16dp"
                                    android:text="Extremis guide"
                                    android:textColor="@color/chrome_muted"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="84dp"
                                android:layout_height="84dp"
                                android:layout_marginStart="12dp"
                                android:background="@drawable/discover_image_bg"
                                android:gravity="center"
                                android:text="TIP"
                                android:textColor="@color/chrome_red"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="16dp"
                            android:background="#ECECF4" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:layout_marginTop="16dp"
                            android:background="@drawable/discover_image_bg"
                            android:gravity="center"
                            android:text="EXTREMIS BROWSER"
                            android:textColor="@color/chrome_text"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/adViewContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/chrome_page_bg"
            android:foregroundGravity="center"
            android:minHeight="50dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tabSwitcherPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/chrome_page_bg"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <ImageButton
                android:id="@+id/newTabButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/new_tab"
                android:padding="8dp"
                android:src="@drawable/ic_add_24" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tabSwitcherCount"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:gravity="center"
                android:textColor="@color/chrome_blue"
                android:textSize="13sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/tabSwitcherMenuButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/menu"
                android:padding="8dp"
                android:src="@drawable/ic_more_vert_24" />
        </LinearLayout>

        <EditText
            android:id="@+id/tabSearchInput"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/chrome_search_bg"
            android:hint="@string/search_your_tabs"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLines="1"
            android:paddingHorizontal="16dp"
            android:singleLine="true"
            android:textColor="@color/chrome_text"
            android:textColorHint="@color/chrome_text"
            android:textSize="14sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/tabsRecycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp" />
    </LinearLayout>
</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:ns1="http://schemas.android.com/tools">
    <color name="black">#000000</color>
    <color name="chip_stroke">#90CAF9</color>
    <color name="chip_text">#1565C0</color>
    <color name="extremis_blue">#1565C0</color>
    <color name="extremis_blue_accent">#2979FF</color>
    <color name="extremis_blue_dark">#0D47A1</color>
    <color name="extremis_blue_light">#42A5F5</color>
    <color name="extremis_blue_surface">#E3F2FD</color>
    <color name="fab_bg">#2962FF</color>
    <color name="fab_icon">#FFFFFF</color>
    <color name="nav_bar_bg">#F5F9FF</color>
    <color name="nav_divider">#BBDEFB</color>
    <color name="page_bg">#FAFCFF</color>
    <color name="ripple_blue">#331565C0</color>
    <color name="toolbar_end">#1976D2</color>
    <color name="toolbar_start">#0D47A1</color>
    <color name="url_bar_bg">#E8F0FE</color>
    <color name="url_bar_hint">#64B5F6</color>
    <color name="url_bar_stroke">#90CAF9</color>
    <color name="url_bar_text">#1A237E</color>
    <color name="white">#FFFFFF</color>
    <style name="Theme.ExtremisBrowser" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/extremis_blue</item>
        <item name="colorPrimaryContainer">@color/extremis_blue_surface</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/extremis_blue_accent</item>
        <item name="colorSurface">@color/page_bg</item>
        <item name="android:statusBarColor">@color/extremis_blue_dark</item>
        <item name="android:navigationBarColor">@color/nav_bar_bg</item>
        <item name="android:windowLightNavigationBar" ns1:targetApi="27">true</item>
        <item name="android:colorControlHighlight">@color/ripple_blue</item>
    </style>
    <style name="Widget.Extremis.NavButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/nav_divider</item>
        <item name="android:textColor">@color/extremis_blue</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:minHeight">38dp</item>
    </style>
    <style name="Widget.Extremis.OutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/chip_stroke</item>
        <item name="android:textColor">@color/chip_text</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:minHeight">36dp</item>
    </style>
</resources>